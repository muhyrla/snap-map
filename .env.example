# ── Домен и HTTPS ────────────────────────────────────────────────────
# ВАЖНО: до запуска заведи A-записи в DNS на IP сервера:
#   snapmap.ru      → <IP>
#   s3.snapmap.ru   → <IP>   (поддомен для загрузки/раздачи фото)
DOMAIN=snapmap.ru
ACME_EMAIL=your@email.com

# ── Postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=snapmap
POSTGRES_PASSWORD=changeme_strong_password

# ── Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password

# ── RabbitMQ ─────────────────────────────────────────────────────────
RABBIT_USER=snapmap
RABBIT_PASS=changeme_rabbit_password

# ── MinIO (S3) ───────────────────────────────────────────────────────
MINIO_ACCESS_KEY=snapmap_minio
MINIO_SECRET_KEY=changeme_minio_secret

# ── Telegram ─────────────────────────────────────────────────────────
SNAP_MAP_BOT_TOKEN=токен_от_botfather

# ── ИИ-проверка фото (воркер, OpenRouter) ────────────────────────────
OPENROUTER_API_KEY=sk-or-...
# необязательные:
# OPENROUTER_MODEL=openai/gpt-4o-mini
# VERIFICATION_THRESHOLD=0.55
