{
    email {$ACME_EMAIL}
}

# ── Основной домен: фронт + API ──────────────────────────────────────
{$DOMAIN} {
    # API запросы → бэкенд
    handle /api/* {
        reverse_proxy backend:8080
    }

    # Всё остальное → фронт
    handle {
        reverse_proxy frontend:80
    }
}

# ── Поддомен под S3 (MinIO) ──────────────────────────────────────────
# Браузер заливает фото по presigned-URL напрямую сюда и отсюда же
# раздаются фото в ленте. Хост совпадает с S3_ENDPOINT бэкенда, иначе
# подпись presigned-URL (SigV4) не сойдётся.
s3.{$DOMAIN} {
    reverse_proxy minio:9000
}
