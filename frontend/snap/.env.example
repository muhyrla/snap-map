# Скопируй в .env.local и подставь адрес своего бэкенда.
#
# Локальный браузер:      http://localhost:8080
# Telegram Mini App:      публичный HTTPS-адрес бэка (туннель/прод),
#                         т.к. Mini App грузится по HTTPS и не может ходить
#                         на http://localhost (mixed content блокируется).
REACT_APP_API_URL=http://localhost:8080
